{
  "builds": [
    {
      "src": "api/check_compliance.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/check_compliance",
      "dest": "api/check_compliance.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}